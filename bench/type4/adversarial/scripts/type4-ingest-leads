#!/usr/bin/env python3
"""Summarize `nose verify --leads` output into frontier target packet drafts."""

from __future__ import annotations

import argparse
import json
from pathlib import Path


def lead_score(lead: dict) -> float:
    return float(lead.get("vj", 0.0)) + (1.0 if lead.get("structurally_near") else 0.0)


def draft_packet(lead: dict, idx: int, axis: str, source: Path) -> dict:
    return {
        "packet_id": f"lead.{axis}.{idx + 1:03d}",
        "candidate_axis": axis,
        "owner_route": "team-a-detector",
        "owner_issue": None,
        "evidence_tier": "detector-suggested",
        "evidence_case_ids": [],
        "semantic_claim": "Verifier lead: behavior-equal units are fingerprint-split.",
        "proof_invariant": "Manual audit required: classify the semantic family and the proof fact needed to merge safely.",
        "hard_negative_siblings": [],
        "blocked_by": [
            "manual audit into real_frontier.v1.json evidence",
            "focused positives and adjacent hard negatives",
        ],
        "current_detector_result": {
            "source": str(source),
            "vj": float(lead.get("vj", 0.0)),
            "structurally_near": bool(lead.get("structurally_near")),
            "a": lead.get("a"),
            "b": lead.get("b"),
        },
        "locations": [],
        "why_now": "Imported from verifier leads; promote only after human evidence links it to real_frontier.v1.json or a generated focused case.",
    }


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("leads_json", type=Path)
    parser.add_argument("--axis", "--family", default="unclassified")
    parser.add_argument("--limit", default=10, type=int)
    parser.add_argument("--draft-json", action="store_true", help="emit target packet drafts")
    args = parser.parse_args()

    payload = json.loads(args.leads_json.read_text())
    leads = list(payload.get("leads", []))
    leads.sort(key=lambda lead: (-lead_score(lead), lead.get("a", ""), lead.get("b", "")))
    selected = leads[: max(args.limit, 0)]

    if args.draft_json:
        print(
            json.dumps(
                [
                    draft_packet(lead, idx, args.axis, args.leads_json)
                    for idx, lead in enumerate(selected)
                ],
                indent=2,
                sort_keys=True,
            )
        )
        return 0

    total = int(payload.get("under_merged_pairs", len(leads)))
    near = int(payload.get("structurally_near", sum(1 for lead in leads if lead.get("structurally_near"))))
    print(f"under-merged pairs: {total}")
    print(f"structurally-near: {near}")
    print()
    if not selected:
        print("No leads found.")
        return 0
    print("top leads:")
    for idx, lead in enumerate(selected, start=1):
        marker = "near" if lead.get("structurally_near") else "low"
        print(
            f"  {idx:2d}. vj={float(lead.get('vj', 0.0)):.2f} [{marker}] "
            f"{lead.get('a')} <-> {lead.get('b')}"
        )
    print()
    print("Use --draft-json to emit target packet drafts for manual frontier curation.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
