#!/usr/bin/env python3
"""Print the next Type-4 frontier target packet task cards."""

from __future__ import annotations

import argparse
import json

from _type4_adversarial import (
    load_all,
    packet_card,
    packet_items,
    packet_score,
    packet_summary,
    validate_all,
)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--limit", default=1, type=int)
    parser.add_argument("--axis", action="append", help="filter by candidate_axis")
    parser.add_argument("--route", action="append", help="filter by owner_route")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    packet_doc, cases, real_frontier = load_all()
    errors = validate_all(packet_doc, cases, real_frontier)
    if errors:
        for error in errors:
            print(f"error: {error}")
        return 1

    packets = packet_items(packet_doc)
    if args.axis:
        allowed = set(args.axis)
        packets = [packet for packet in packets if packet.get("candidate_axis") in allowed]
    if args.route:
        allowed = set(args.route)
        packets = [packet for packet in packets if packet.get("owner_route") in allowed]
    packets = sorted(packets, key=lambda packet: (-packet_score(packet), packet["packet_id"]))
    selected = packets[: max(args.limit, 0)]

    if args.json:
        print(json.dumps([packet_summary(packet) for packet in selected], indent=2, sort_keys=True))
        return 0

    if not selected:
        print("No Type-4 frontier target packets matched the filters.")
        return 0
    for idx, packet in enumerate(selected):
        if idx:
            print("\n" + "-" * 78 + "\n")
        print(packet_card(packet))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
