#!/usr/bin/env python3
"""Summarize Type-4 target packets and focused cases."""

from __future__ import annotations

import argparse
from collections import Counter

from _type4_adversarial import case_items, load_all, packet_items, packet_score, validate_all


def print_counter(title: str, counter: Counter[str]) -> None:
    print(f"\n{title}:")
    for key, count in sorted(counter.items()):
        print(f"  {key}: {count}")


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--limit", default=10, type=int)
    args = parser.parse_args()

    packet_doc, cases, real_frontier = load_all()
    errors = validate_all(packet_doc, cases, real_frontier)
    if errors:
        for error in errors:
            print(f"error: {error}")
        return 1

    packets = packet_items(packet_doc)
    focused_cases = case_items(cases)
    print(f"target packets: {len(packets)}")
    print(f"focused cases: {len(focused_cases)}")
    print(f"real-frontier items: {len(real_frontier.get('items', []))}")

    print_counter("packets by route", Counter(packet["owner_route"] for packet in packets))
    print_counter("packets by axis", Counter(packet["candidate_axis"] for packet in packets))
    print_counter("packets by evidence tier", Counter(packet["evidence_tier"] for packet in packets))
    print_counter("focused cases by kind", Counter(case["kind"] for case in focused_cases))
    print_counter("focused cases by semantic family", Counter(case["semantic_family"] for case in focused_cases))

    print("\nnext packets:")
    for packet in sorted(packets, key=lambda packet: (-packet_score(packet), packet["packet_id"]))[
        : args.limit
    ]:
        issue = f" {packet['owner_issue']}" if packet.get("owner_issue") else ""
        print(
            f"  {packet_score(packet):4d}  {packet['packet_id']}  "
            f"[{packet['owner_route']}{issue}]"
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
