#!/usr/bin/env python3
"""Validate Type-4 target packets and focused case handles."""

from __future__ import annotations

import argparse
import json
import sys

from _type4_adversarial import (
    case_card,
    case_items,
    find_case,
    find_packet,
    load_all,
    packet_card,
    packet_items,
    validate_all,
)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--item", help="print one target packet or focused case")
    parser.add_argument("--json", action="store_true", help="emit machine-readable summary")
    args = parser.parse_args()

    packet_doc, cases, real_frontier = load_all()
    errors = validate_all(packet_doc, cases, real_frontier)
    packet = case = None
    if args.item:
        packet = find_packet(packet_doc, args.item)
        case = find_case(cases, args.item)
        if packet is None and case is None:
            errors.append(f"unknown target packet or focused case: {args.item}")

    summary = {
        "ok": not errors,
        "errors": errors,
        "target_packets": len(packet_items(packet_doc)),
        "focused_cases": len(case_items(cases)),
        "real_frontier_items": len(real_frontier.get("items", [])),
    }
    if args.json:
        print(json.dumps(summary, indent=2, sort_keys=True))
    else:
        if errors:
            print("Type-4 target packet/focused case check failed:", file=sys.stderr)
            for error in errors:
                print(f"  - {error}", file=sys.stderr)
        else:
            print(
                "ok: "
                f"{summary['target_packets']} target packets, "
                f"{summary['focused_cases']} focused cases, "
                f"{summary['real_frontier_items']} real-frontier items"
            )
        if packet is not None:
            print()
            print(packet_card(packet))
        if case is not None:
            print()
            print(case_card(case))
    return 1 if errors else 0


if __name__ == "__main__":
    raise SystemExit(main())
